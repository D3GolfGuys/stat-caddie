# ── Database ──────────────────────────────────────────
# Railway provides this automatically. For local dev, use a local PostgreSQL URL.
DATABASE_URL=postgresql://user:password@localhost:5432/statcaddie

# ── Auth ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ── Stripe ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Create these in your Stripe dashboard under Products
STRIPE_INDIVIDUAL_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...

# ── App ───────────────────────────────────────────────
APP_URL=http://localhost:3000
NODE_ENV=development
PORT=3000

# ── Email (optional — for team invitations) ───────────
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key
# FROM_EMAIL=noreply@statcaddie.com
